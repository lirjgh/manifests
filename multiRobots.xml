  <project path="mujoco"   name="google-deepmind/mujoco"    remote="github"    revision="main" />
  <project path="newton"   name="newton-physics/newton"     remote="github"    revision="main" />
  <project path="WorldEngine"   name="OpenDriveLab/WorldEngine"   remote="github"   revision="main" />


