<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- ============================================================
       自定义机器人项目 (Custom Robotics Projects)
       占位项目 - 请将 org/ 替换为实际的仓库组织/用户名。
       
       属性说明：
       - path:     本地检出路径（相对于工作区根目录）
       - name:     远程仓库路径（拼接在 remote.fetch 之后）
       - remote:   使用的远程仓库定义名称
       - revision: 分支名、标签名或 commit hash
       ============================================================ -->
 

  <!-- robotics项目-->
  <project path="Psi0"  name="physical-superintelligence-lab/Psi0" remote="github"   revision="main" />
