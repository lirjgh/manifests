  <project path="eclipse-threadx/threadx"  name="eclipse-threadx/threadx" remote="github"    revision="main" />
  <project path="ros2/ros2"  name="ros2/ros2" remote="github"    revision="main" />
 
  <!-- 工具项目 - Bitbucket 仓库 -->


